{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "AI 장애예측 점수 (5 노드 self-monitoring)",
  "uid": "ai-pred-scores",
  "tags": ["ai", "ensemble", "failure-prediction", "self-monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "현재 위험도 (5 노드)",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_score{target_type=\"node\"}",
        "legendFormat": "{{target_id}}",
        "instant": true
      }],
      "fieldConfig": {"defaults": {
        "unit": "percentunit",
        "min": 0, "max": 1,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "blue",   "value": null},
          {"color": "green",  "value": 0.30},
          {"color": "yellow", "value": 0.65},
          {"color": "red",    "value": 0.85}
        ]},
        "mappings": []
      }},
      "options": {"orientation": "horizontal", "colorMode": "background", "graphMode": "area", "textMode": "value_and_name"}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "노드 5대 — failure_pred_score 추세",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_score{target_type=\"node\"}",
        "legendFormat": "{{target_id}}"
      }],
      "fieldConfig": {"defaults": {
        "unit": "percentunit",
        "min": 0, "max": 1,
        "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
      }}
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "위험 상태 타임라인 (RECOVERY=0 / NORMAL=1 / WARNING=2 / CRITICAL=3)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_risk_level{target_type=\"node\"}",
        "legendFormat": "{{target_id}}"
      }],
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "blue",   "value": null},
          {"color": "green",  "value": 1},
          {"color": "yellow", "value": 2},
          {"color": "red",    "value": 3}
        ]},
        "mappings": [{"options": {
          "0": {"text": "RECOVERY", "color": "blue"},
          "1": {"text": "NORMAL",   "color": "green"},
          "2": {"text": "WARNING",  "color": "yellow"},
          "3": {"text": "CRITICAL", "color": "red"}
        }, "type": "value"}]
      }}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "node1 (control-plane + GPU) — model breakdown",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_model_score{target_type=\"node\",target_id=\"node1\"}",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "node4 (RTX 5080) — model breakdown",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_model_score{target_type=\"node\",target_id=\"node4\"}",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "node5 (NPU) — model breakdown",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "datasource": {"type": "prometheus", "uid": "victoria-metrics"},
      "targets": [{
        "expr": "failure_pred_model_score{target_type=\"node\",target_id=\"node5\"}",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    }
  ]
}
