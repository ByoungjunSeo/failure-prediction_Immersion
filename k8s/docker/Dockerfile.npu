# Furiosa RNGD NPU 추론용 — furiosa-llm 2026.2 + Qwen3 Embedding
# 베이스: Ubuntu 22.04 (node5 OS와 동일)
FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive \
    HF_HOME=/artifacts/.hf \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.10 python3.10-venv python3-pip \
        curl ca-certificates && \
    ln -sf /usr/bin/python3.10 /usr/bin/python3 && \
    ln -sf /usr/bin/python3 /usr/bin/python && \
    pip install --upgrade pip && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# furiosa-llm 2026.2.1 — RNGD pooling 모델 지원 (Qwen3 Embedding)
# (transformers/torch/ray 등 모두 deps로 함께 설치됨)
RUN pip install --no-cache-dir furiosa-llm==2026.2.1

COPY scripts/build_npu_artifact.py /app/build_npu_artifact.py
COPY scripts/npu_serve_entrypoint.sh /app/npu_serve_entrypoint.sh
RUN chmod +x /app/npu_serve_entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/app/npu_serve_entrypoint.sh"]
